rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // bootstrap owner emails — always admin
    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email in ['zahredden1212@gmail.com'];
    }

    // helper: is the signed-in user an admin?
    function isAdmin() {
      return isSuperAdmin()
        || (request.auth != null
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // USERS: a user manages their own doc; admins can read everyone
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      // a user can update their own doc but NOT change their own role; admins can do anything
      allow update: if isAdmin()
        || (request.auth.uid == uid
            && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();

      // wallet transaction history (subcollection needs its own rule)
      match /walletTxns/{txn} {
        allow read, create: if request.auth != null && request.auth.uid == uid;
      }
    }

    // RESERVATIONS: a user sees/creates their own; admins see all
    match /reservations/{id} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // PARKING LOTS: anyone can read; only admins write
    match /lots/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ADS & NEWS: anyone can read; only admins write
    match /ads/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /news/{id} {
      allow read: if true;
      allow write: if isAdmin();
      // anyone signed in can react / mark viewed via a subcollection
      match /reactions/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /views/{uid} {
        allow read: if isAdmin();
        allow create: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
